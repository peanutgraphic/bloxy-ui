{
    "name": "peanutgraphic/bloxy-ui",
    "description": "BLOXY UI PHP companion — publishes Tailwind preset + Vite plugin paths for the @peanutgraphic/bloxy-ui npm package.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Bloxy\\Ui\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bloxy\\Ui\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bloxy\\Ui\\BloxyUiServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
